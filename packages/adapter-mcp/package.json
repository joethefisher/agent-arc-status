  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agent-arc-status/reference": "^0.3.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": { "optional": true }
  }
