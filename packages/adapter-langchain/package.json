{
  "name": "@agent-arc-status/adapter-langchain",
  "version": "0.3.2",
  "description": "A LangChain callback handler that emits Agent Arc Status Protocol events at chain/agent boundaries.",
  "license": "MIT",
  "author": "Joe Fisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/joethefisher/agent-arc-status.git",
    "directory": "packages/adapter-langchain"
  },
  "homepage": "https://github.com/joethefisher/agent-arc-status#readme",
  "bugs": "https://github.com/joethefisher/agent-arc-status/issues",
  "keywords": [
    "agent",
    "arc-status",
    "langchain",
    "callbacks"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agent-arc-status/reference": "^0.3.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  }
}
