{
  "name": "@agent-arc-status/reference",
  "version": "0.2.0",
  "description": "Reference implementation of the Agent Arc Status Protocol: types, parser, validator, renderer. Zero runtime dependencies.",
  "license": "MIT",
  "author": "Joe Fisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/joethefisher/agent-arc-status.git",
    "directory": "reference/node"
  },
  "homepage": "https://github.com/joethefisher/agent-arc-status#readme",
  "bugs": "https://github.com/joethefisher/agent-arc-status/issues",
  "keywords": [
    "agent",
    "agents",
    "ai",
    "llm",
    "observability",
    "progress",
    "webhook",
    "arc-status"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "ajv": "^8.17.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
